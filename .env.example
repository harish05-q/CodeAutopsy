# CodeAutopsy Environment Variables
# Copy this file to .env and fill in your values

# Application
CODEAUTOPSY_DEBUG=true
CODEAUTOPSY_LOG_LEVEL=DEBUG

# Groq LLM API Key
CODEAUTOPSY_GROQ_API_KEY=your-groq-api-key-here

# Paths (defaults are fine for development)
# CODEAUTOPSY_DATA_DIR=./data
# CODEAUTOPSY_REPOS_DIR=./data/repos
# CODEAUTOPSY_ARTIFACTS_DIR=./data/artifacts

# Database (defaults to SQLite)
# CODEAUTOPSY_DATABASE_URL=sqlite:///./data/codeautopsy.db
